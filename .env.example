# Recommended for server deploys: pin to the immutable GHCR tree tag generated
# by the local .githooks/pre-commit hook and written to scanner-image.env.
# Example:
# SCANNER_IMAGE=ghcr.io/wanglz111/arb-arbitrage:tree-<staged-tree-hash>
#
# If omitted, docker-compose.yml falls back to :latest for convenience.
# SCANNER_IMAGE=ghcr.io/wanglz111/arb-arbitrage:latest

RUST_LOG=scanner=info

HTTP_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
LOG_RPC_URL=https://arb1.arbitrum.io/rpc
LOG_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
QUOTE_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

SCANNER_MAX_LOG_BLOCK_RANGE=10
SCANNER_RPC_RETRY_MS=2000
SCANNER_WS_RECONNECT_MS=2000
SCANNER_MIN_EDGE_BPS=0
SCANNER_MIN_LOCAL_EDGE_BPS=0
SCANNER_MIN_PROFIT_USD=1
SCANNER_ROUGH_SHORTLIST_SIZE=3
SCANNER_EXACT_QUOTE_ENABLED=false
SCANNER_MAX_EXACT_QUOTES_PER_BLOCK=1
EXECUTION_CALL_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
SCANNER_EXECUTION_CALL_ENABLED=false
SCANNER_REQUIRE_EXECUTION_CALL=false
SCANNER_EXECUTOR_ADDRESS=
SCANNER_EXECUTOR_CALLER=
SCANNER_EXECUTION_CALL_MODE=direct
SCANNER_MAX_EXECUTION_CALLS_PER_BLOCK=1
SCANNER_DEBUG_SUMMARY_ENABLED=true
SCANNER_DEBUG_JSONL_PATH=data/directional-candidates.jsonl
SCANNER_ROUTE_CATALOG_PATH=data/route-catalog.jsonl
